/* ═══════════════════════════════════════════════════════════════════
   MODAL DIALOG — Stili completi dark theme
   Importare in dark-theme.css:  @import "modal.css";
   ═══════════════════════════════════════════════════════════════════ */

/* ── Backdrop ──────────────────────────────────────────────────── */
.modal-backdrop {
    -fx-background-color: rgba(0, 0, 0, 0.72);
    -fx-background-radius: 0;
}

/* ── Dialog card ───────────────────────────────────────────────── */
.modal-dialog {
    -fx-background-color: #1c2128;
    -fx-border-color: #30363d;
    -fx-border-radius: 16;
    -fx-background-radius: 16;
    -fx-border-width: 1;
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 32, 0, 0, 8);
}

/* Accent sinistra per tipo */
.modal-type-info    { -fx-border-color: #30363d #30363d #30363d #58a6ff; -fx-border-width: 1 1 1 3; }
.modal-type-success { -fx-border-color: #30363d #30363d #30363d #3fb950; -fx-border-width: 1 1 1 3; }
.modal-type-warning { -fx-border-color: #30363d #30363d #30363d #e3b341; -fx-border-width: 1 1 1 3; }
.modal-type-error   { -fx-border-color: #30363d #30363d #30363d #f85149; -fx-border-width: 1 1 1 3; }
.modal-type-confirm { -fx-border-color: #30363d #30363d #30363d #8b949e; -fx-border-width: 1 1 1 3; }
.modal-type-input   { -fx-border-color: #30363d #30363d #30363d #58a6ff; -fx-border-width: 1 1 1 3; }
.modal-type-loading { -fx-border-color: #30363d; -fx-border-width: 1; }
.modal-type-custom  { -fx-border-color: #30363d; -fx-border-width: 1; }

/* ── Header ────────────────────────────────────────────────────── */
.modal-header {
    -fx-background-color: transparent;
}

.modal-title {
    -fx-font-family: "IBM Plex Sans";
    -fx-font-size: 16px;
    -fx-font-weight: 600;
    -fx-text-fill: #e6edf3;
}

.modal-subtitle {
    -fx-font-family: "IBM Plex Sans";
    -fx-font-size: 12px;
    -fx-font-weight: 400;
    -fx-text-fill: #8b949e;
    -fx-padding: 2 0 0 0;
}

/* ── Icona tipo ─────────────────────────────────────────────────── */
.modal-icon {
    -fx-font-size: 22px;
    -fx-font-weight: 600;
    -fx-padding: 2 4 0 0;
}
.modal-icon-info    { -fx-text-fill: #58a6ff; }
.modal-icon-success { -fx-text-fill: #3fb950; }
.modal-icon-warning { -fx-text-fill: #e3b341; }
.modal-icon-error   { -fx-text-fill: #f85149; }
.modal-icon-confirm { -fx-text-fill: #8b949e; }
.modal-icon-input   { -fx-text-fill: #58a6ff; }

/* ── Pulsante chiusura [✕] ─────────────────────────────────────── */
.modal-close-btn {
    -fx-background-color: transparent;
    -fx-border-color: transparent;
    -fx-text-fill: #6e7681;
    -fx-font-size: 14px;
    -fx-cursor: hand;
    -fx-padding: 4 6 4 6;
    -fx-background-radius: 6;
    -fx-min-width: 28px;
    -fx-min-height: 28px;
}
.modal-close-btn:hover {
    -fx-background-color: #21262d;
    -fx-text-fill: #e6edf3;
}

/* ── Divider ───────────────────────────────────────────────────── */
.modal-divider {
    -fx-background-color: #21262d;
}

/* ── Body ──────────────────────────────────────────────────────── */
.modal-body {
    -fx-background-color: transparent;
}

.modal-message {
    -fx-font-family: "IBM Plex Sans";
    -fx-font-size: 14px;
    -fx-font-weight: 400;
    -fx-text-fill: #c9d1d9;
    -fx-line-spacing: 4;
}

.modal-loading-label {
    -fx-font-family: "IBM Plex Sans";
    -fx-font-size: 14px;
    -fx-text-fill: #8b949e;
    -fx-text-alignment: center;
}

/* Campo di input nel modal */
.modal-input-field {
    -fx-background-color: #0d1117;
    -fx-border-color: #30363d;
    -fx-border-radius: 8;
    -fx-background-radius: 8;
    -fx-border-width: 1;
    -fx-text-fill: #e6edf3;
    -fx-font-size: 14px;
    -fx-font-family: "IBM Plex Sans";
    -fx-padding: 10 12 10 12;
    -fx-pref-height: 44px;
}
.modal-input-field:focused {
    -fx-border-color: #58a6ff;
    -fx-effect: dropshadow(gaussian, rgba(88,166,255,0.15), 6, 0, 0, 0);
}
.modal-input-field .prompt-text { -fx-fill: #484f58; }

/* ProgressIndicator nel loading modal */
.modal-progress .percentage { -fx-fill: transparent; }
.modal-progress .progress-color { -fx-background-color: #58a6ff; }
.modal-progress .track { -fx-background-color: #21262d; }

/* ── Footer ────────────────────────────────────────────────────── */
.modal-footer {
    -fx-background-color: transparent;
}
.modal-footer-multi {
    -fx-spacing: 8;
}

/* ── Bottoni modal ─────────────────────────────────────────────── */
.modal-btn {
    -fx-font-family: "IBM Plex Sans";
    -fx-font-size: 13px;
    -fx-font-weight: 500;
    -fx-cursor: hand;
    -fx-padding: 10 20 10 20;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-border-width: 1;
    -fx-pref-height: 40px;
    -fx-min-width: 80px;
}

/* Primary */
.modal-btn-primary {
    -fx-background-color: #1a4b9b;
    -fx-border-color: #1a4b9b;
    -fx-text-fill: #ffffff;
}
.modal-btn-primary:hover {
    -fx-background-color: #2059bc;
    -fx-border-color: #2059bc;
}
.modal-btn-primary:pressed { -fx-scale-x: 0.97; -fx-scale-y: 0.97; }

/* Danger */
.modal-btn-danger {
    -fx-background-color: rgba(218,54,51,0.15);
    -fx-border-color: #da3633;
    -fx-text-fill: #f85149;
}
.modal-btn-danger:hover {
    -fx-background-color: #da3633;
    -fx-text-fill: #ffffff;
}
.modal-btn-danger:pressed { -fx-scale-x: 0.97; -fx-scale-y: 0.97; }

/* Success */
.modal-btn-success {
    -fx-background-color: rgba(46,160,67,0.15);
    -fx-border-color: #238636;
    -fx-text-fill: #3fb950;
}
.modal-btn-success:hover {
    -fx-background-color: #238636;
    -fx-text-fill: #ffffff;
}

/* Warning */
.modal-btn-warning {
    -fx-background-color: rgba(210,153,34,0.15);
    -fx-border-color: #d29922;
    -fx-text-fill: #e3b341;
}
.modal-btn-warning:hover {
    -fx-background-color: #d29922;
    -fx-text-fill: #1c2128;
}

/* Ghost / secondario */
.modal-btn-ghost {
    -fx-background-color: transparent;
    -fx-border-color: #30363d;
    -fx-text-fill: #c9d1d9;
}
.modal-btn-ghost:hover {
    -fx-background-color: #21262d;
    -fx-border-color: #8b949e;
    -fx-text-fill: #e6edf3;
}
.modal-btn-ghost:pressed { -fx-scale-x: 0.97; -fx-scale-y: 0.97; }

/* Animazione feedback tutti i bottoni */
.modal-btn:armed { -fx-opacity: 0.85; }
