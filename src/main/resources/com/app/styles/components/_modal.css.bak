/* ══════════════════════════════════════════════════════════════════════════════
 *  components/_modal.css
 *  Modal prodotto, ModalDialog (info/warning/error), Confirm modal.
 *  Dipende dai token in _variables-*.css.
 * ══════════════════════════════════════════════════════════════════════════════ */

/* ─────────────────────────────────────────────────────────────────────────────
 *  1. Modal prodotto  (overlay + card grande con scroll)
 * ───────────────────────────────────────────────────────────────────────────── */

.modal-overlay {
    -fx-background-color: rgba(0, 0, 0, 0.50);
}

.modal-card {
    -fx-background-color:  -color-surface;
    -fx-background-radius: 22;
    -fx-border-color:      -color-border;
    -fx-border-radius:     22;
    -fx-border-width:      1;
    -fx-max-width:         860;
    -fx-min-width:         400;
    -fx-max-height:        920;
    -fx-effect:            dropshadow(gaussian, rgba(0,0,0,0.22), 28, 0, 0, 8);
}

.modal-header {
    -fx-padding:           28 28 22 28;
    -fx-background-radius: 22 22 0 0;
    -fx-border-color:      transparent transparent -color-border transparent;
    -fx-border-width:      0 0 1 0;
}

.modal-title {
    -fx-font-size:   28px;
    -fx-font-weight: bold;
    -fx-text-fill:   -color-text;
    -fx-wrap-text:   true;
}

.modal-price {
    -fx-font-size:   34px;
    -fx-font-weight: bold;
    -fx-text-fill:   -color-accent;
}

.modal-body-scroll {
    -fx-background-color: transparent;
    -fx-border-color:     transparent;
}
.modal-body-scroll > .viewport {
    -fx-background-color: transparent;
}

.modal-body {
    -fx-background-color: transparent;
    -fx-padding:          22 28 28 28;
}

.modal-desc {
    -fx-font-size:    17px;
    -fx-text-fill:    -color-muted;
    -fx-line-spacing: 3;
}

.modal-section-label {
    -fx-font-size:   14px;
    -fx-font-weight: bold;
    -fx-text-fill:   -color-dim;
    -fx-padding:     0 0 4 0;
}

.modal-close {
    -fx-min-width:         46px;
    -fx-min-height:        46px;
    -fx-max-width:         46px;
    -fx-max-height:        46px;
    -fx-font-size:         18px;
    -fx-font-weight:       bold;
    -fx-background-radius: 50%;
    -fx-border-radius:     50%;
    -fx-background-color:  rgba(0, 0, 0, 0.06);
    -fx-border-color:      -color-border;
    -fx-text-fill:         -color-text;
    -fx-cursor:            hand;
    -fx-padding:           0;
}
.modal-close:pressed {
    -fx-background-color: rgba(192, 48, 48, 0.15);
    -fx-border-color:     -color-red;
}

/* Immagine overlay sfumato */
.prod-card-img-overlay {
    -fx-background-color: linear-gradient(to bottom,
        transparent 40%,
        rgba(0, 0, 0, 0.45) 100%);
}

/* Pulsante aggiungi al carrello (footer modal) */
.add-to-cart-btn {
    -fx-background-color: linear-gradient(to bottom, -color-green, derive(-color-green, -15%));
    -fx-text-fill:        white;
    -fx-font-size:        20px;
    -fx-font-weight:      bold;
    -fx-background-radius: 0 0 22 22;
    -fx-padding:          20 24;
    -fx-cursor:           hand;
}
.add-to-cart-btn:pressed {
    -fx-background-color: derive(-color-green, -25%);
}

/* ... resto invariato ... */

/* Pulsante carrello floating */
.cart-btn {
    -fx-background-color:  -color-surface2;
    -fx-border-color:      -color-border;
    -fx-border-radius:     16;
    -fx-background-radius: 16;
    -fx-font-size:         28px;
    -fx-min-width:  64;
    -fx-min-height: 64;
    -fx-max-width:  64;
    -fx-max-height: 64;
    -fx-cursor:     hand;
    -fx-padding:    0;
}
.cart-btn:pressed {
    -fx-background-color: -color-border;
}

.cart-badge {
    -fx-background-color:  -color-red;
    -fx-background-radius: 14;
    -fx-text-fill:         white;
    -fx-font-size:         14px;
    -fx-font-weight:       bold;
    -fx-min-width:  28;
    -fx-min-height: 28;
    -fx-max-width:  28;
    -fx-max-height: 28;
    -fx-alignment:  center;
    -fx-translate-x: 8;
    -fx-translate-y: -8;
}

.quick-cart-btn {
    -fx-background-color:  -color-accent;
    -fx-text-fill:         white;
    -fx-border-radius:     14;
    -fx-background-radius: 14;
    -fx-background-insets: 0;
    -fx-border-insets:     0;
    -fx-padding:           0 18;
    -fx-min-width:  160;
    -fx-min-height: 54;
    -fx-max-width:  240;
    -fx-max-height: 54;
    -fx-cursor:     hand;
    -fx-effect:     dropshadow(gaussian, rgba(0,0,0,0.30), 14, 0, 0, 0);
}
.quick-cart-btn:hover {
    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.40), 18, 0, 0, 0);
}
.quick-cart-btn:pressed {
    -fx-background-color: derive(-color-accent, -10%);
    -fx-effect:           dropshadow(gaussian, rgba(0,0,0,0.25), 12, 0, 0, 0);
}

/* ... resto invariato fino alla fine ... */

/* ModalDialog */
.modal-backdrop {
    -fx-background-color:  rgba(0, 0, 0, 0.72);
    -fx-background-radius: 0;
}

.modal-dialog {
    -fx-background-color:  -color-surface;
    -fx-border-color:      -color-border;
    -fx-border-radius:     16;
    -fx-background-radius: 16;
    -fx-border-width:      1;
    -fx-effect:            dropshadow(gaussian, rgba(0,0,0,0.30), 32, 0, 0, 8);
}

.modal-dialog .modal-header {
    -fx-background-color: transparent;
    -fx-padding:          0;
    -fx-border-width:     0;
}

.modal-dialog-title {
    -fx-font-size:   16px;
    -fx-font-weight: 600;
    -fx-text-fill:   -color-text;
}

.modal-dialog-subtitle {
    -fx-font-size:   12px;
    -fx-font-weight: 400;
    -fx-text-fill:   -color-muted;
    -fx-padding:     2 0 0 0;
}

.modal-icon {
    -fx-font-size:   22px;
    -fx-font-weight: 600;
    -fx-padding:     2 4 0 0;
}

.modal-close-btn {
    -fx-background-color:  transparent;
    -fx-border-color:      transparent;
    -fx-text-fill:         -color-dim;
    -fx-font-size:         14px;
    -fx-cursor:            hand;
    -fx-padding:           4 6 4 6;
    -fx-background-radius: 6;
    -fx-min-width:         28px;
    -fx-min-height:        28px;
}
.modal-close-btn:hover {
    -fx-background-color: -color-surface2;
    -fx-text-fill:        -color-text;
}

.modal-divider {
    -fx-background-color: -color-surface2;
}

.modal-message {
    -fx-font-size:    14px;
    -fx-font-weight:  400;
    -fx-text-fill:    -color-muted;
    -fx-line-spacing: 4;
}

.modal-loading-label {
    -fx-font-size:      14px;
    -fx-text-fill:      -color-muted;
    -fx-text-alignment: center;
}

.modal-input-field {
    -fx-background-color:  -color-bg;
    -fx-border-color:      -color-border;
    -fx-border-radius:     8;
    -fx-background-radius: 8;
    -fx-border-width:      1;
    -fx-text-fill:         -color-text;
    -fx-font-size:         14px;
    -fx-padding:           10 12 10 12;
    -fx-pref-height:       44px;
}
.modal-input-field:focused {
    -fx-border-color: -color-accent;
    -fx-effect:       dropshadow(gaussian, rgba(88,166,255,0.15), 6, 0, 0, 0);
}
.modal-input-field .prompt-text { -fx-fill: -color-dim; }

.modal-progress .percentage    { -fx-fill: transparent;    }
.modal-progress .progress-color { -fx-background-color: -color-accent; }
.modal-progress .track          { -fx-background-color: -color-surface2; }

.modal-footer       { -fx-background-color: transparent; }
.modal-footer-multi { -fx-spacing: 8; }

.modal-btn {
    -fx-font-size:         13px;
    -fx-font-weight:       500;
    -fx-cursor:            hand;
    -fx-padding:           10 20 10 20;
    -fx-background-radius: 8;
    -fx-border-radius:     8;
    -fx-border-width:      1;
    -fx-pref-height:       40px;
    -fx-min-width:         80px;
}
.modal-btn:armed { -fx-opacity: 0.85; }

.modal-btn-primary {
    -fx-background-color: #58a6ff;
    -fx-border-color:     #58a6ff;
    -fx-text-fill:        #ffffff;
}
.modal-btn-primary:hover {
    -fx-background-color: #70b8ff;
    -fx-border-color:     #70b8ff;
}
.modal-btn-primary:pressed { -fx-scale-x: 0.97; -fx-scale-y: 0.97; }

.modal-btn-danger {
    -fx-background-color: rgba(248,81,73, 0.15); /* #f85149 */
    -fx-border-color:     #f85149;
    -fx-text-fill:        #f85149;
}
.modal-btn-danger:hover {
    -fx-background-color: -color-red;
    -fx-text-fill:        #ffffff;
}
.modal-btn-danger:pressed { -fx-scale-x: 0.97; -fx-scale-y: 0.97; }

.modal-btn-success {
    -fx-background-color: rgba(63,185,80, 0.15); /* #3fb950 */
    -fx-border-color:     #3fb950;
    -fx-text-fill:        #3fb950;
}
.modal-btn-success:hover {
    -fx-background-color: -color-green;
    -fx-text-fill:        #ffffff;
}

.modal-btn-warning {
    -fx-background-color: rgba(176,101,32, 0.15); /* #b06520 */
    -fx-border-color:     #b06520;
    -fx-text-fill:        #b06520;
}
.modal-btn-warning:hover {
    -fx-background-color: -color-orange;
    -fx-text-fill:        -color-surface;
}

.modal-btn-ghost {
    -fx-background-color: transparent;
    -fx-border-color:     -color-border;
    -fx-text-fill:        -color-muted;
}
.modal-btn-ghost:hover {
    -fx-background-color: -color-surface2;
    -fx-border-color:     -color-muted;
    -fx-text-fill:        -color-text;
}
.modal-btn-ghost:pressed { -fx-scale-x: 0.97; -fx-scale-y: 0.97; }

/* ─────────────────────────────────────────────────────────────────────────────
 *  3. Confirm modal  (ConfirmDialog.fxml / ConfirmModal.fxml)
 * ───────────────────────────────────────────────────────────────────────────── */

.confirm-root {
    -fx-background-color: rgba(0, 0, 0, 0.55);
}

.confirm-container {
    -fx-background-color:  -color-surface;
    -fx-background-radius: 24;
    -fx-padding:           28;
    -fx-alignment:         center;
    -fx-min-width:         340;
}

.confirm-title {
    -fx-font-size:   24px;
    -fx-font-weight: bold;
    -fx-text-fill:   -color-text;
}

.confirm-msg {
    -fx-font-size: 16px;
    -fx-text-fill: -color-muted;
}

.confirm-btn-primary {
    -fx-background-color: -color-accent;
    -fx-text-fill:        -color-text;
}
.confirm-btn-primary:hover {
    -fx-background-color: derive(-color-accent, -10%);
}

.confirm-btn-secondary {
    -fx-background-color: rgba(0, 0, 0, 0.10);
    -fx-text-fill:        -color-text;
}
.confirm-btn-secondary:hover {
    -fx-background-color: rgba(0, 0, 0, 0.15);
}