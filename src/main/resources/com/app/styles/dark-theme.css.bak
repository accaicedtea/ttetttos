/* ══════════════════════════════════════════════════════════════════════════════
 *  DARK THEME — Totem Touch UI
 * ══════════════════════════════════════════════════════════════════════════════ */

.root {
    -color-bg: #16161e;
    -color-surface: #1e1e2a;
    -color-surface2: #252534;
    -color-border: #2c2c40;
    -color-sidebar: #111118;
    -color-accent: #5b9cf5;
    -color-text: #e4e4f0;
    -color-muted: #9090b0;
    -color-dim: #606080;
    -color-green: #4ec97a;
    -color-orange: #e0a040;
    -color-red: #e05555;

    -fx-base: -color-surface;
    -fx-background: -color-bg;
    -fx-control-inner-background: -color-surface;
    -fx-text-fill: -color-text;
    -fx-font-family: "Segoe UI", "Noto Color Emoji", "Noto Emoji", "Apple Color Emoji", "Ubuntu", sans-serif;
    -fx-font-size: 16px;
    -fx-focus-color: transparent;
    -fx-faint-focus-color: transparent;
}

/* ── Struttura ───────────────────────────────────────────────────────────── */
.main-pane {
    -fx-background-color: -color-bg;
}

.top-container {
    -fx-background-color: transparent;
}

/* ── Status bar ──────────────────────────────────────────────────────────── */
.status-bar {
    -fx-background-color: #0d0d14;
    -fx-padding: 6 22;
    -fx-min-height: 38;
    -fx-border-color: transparent transparent -color-border transparent;
    -fx-border-width: 0 0 1 0;
}

.status-clock {
    -fx-text-fill: -color-text;
    -fx-font-size: 15px;
    -fx-font-weight: bold;
    -fx-font-family: monospace;
}

.status-date {
    -fx-text-fill: -color-muted;
    -fx-font-size: 14px;
    -fx-font-family: monospace;
}

.status-text {
    -fx-text-fill: -color-muted;
    -fx-font-size: 14px;
}

.status-dot-online {
    -fx-background-color: -color-green;
    -fx-background-radius: 50%;
    -fx-min-width: 11px;
    -fx-min-height: 11px;
    -fx-max-width: 11px;
    -fx-max-height: 11px;
    -fx-effect: dropshadow(gaussian, rgba(78, 201, 122, 0.7), 5, 0, 0, 0);
}

.status-dot-offline {
    -fx-background-color: -color-red;
    -fx-background-radius: 50%;
    -fx-min-width: 11px;
    -fx-min-height: 11px;
    -fx-max-width: 11px;
    -fx-max-height: 11px;
    -fx-effect: dropshadow(gaussian, rgba(224, 85, 85, 0.7), 5, 0, 0, 0);
}

/* ── Header ──────────────────────────────────────────────────────────────── */
.shop-header {
    -fx-background-color: #10101a;
    -fx-padding: 16 24;
    -fx-min-height: 72;
    -fx-border-color: transparent transparent -color-border transparent;
    -fx-border-width: 0 0 1 0;
}

/* ⚠️ CONFLITTO: ".shop-header-icon" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.shop-header-icon {
    -fx-font-size: 32px;
}

.shop-header-title {
    -fx-font-size: 24px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-accent;
}

.shop-header-hint {
    -fx-font-size: 15px;
    -fx-text-fill: -color-muted;
}

/* ⚠️ CONFLITTO: ".theme-btn" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


.theme-btn {
    -fx-background-color: -color-surface2;
    -fx-border-color: -color-border;
    -fx-border-radius: 50%;
    -fx-background-radius: 50%;
    -fx-font-size: 18px;
    -fx-min-width: 44px;
    -fx-min-height: 44px;
    -fx-max-width: 44px;
    -fx-max-height: 44px;
    -fx-cursor: hand;
    -fx-padding: 0;
}

/* RIMOSSO: .theme-btn:pressed  (duplicato esatto della riga 848) */


/* ── Categorie (sinistra) ────────────────────────────────────────────────── */
.categories-scroll {
    -fx-background: -color-sidebar;
    -fx-background-color: -color-sidebar;
    -fx-border-color: transparent -color-border transparent transparent;
    -fx-border-width: 0 1 0 0;
    -fx-pref-width: 280;
    -fx-min-width: 260;
    -fx-max-width: 320;
}

.categories-scroll>.viewport {
    -fx-background-color: -color-sidebar;
}

.categories-pane {
    -fx-background-color: -color-sidebar;
    -fx-padding: 12 8;
}

.category-tab {
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-muted;
    -fx-padding: 20 20;
    -fx-min-height: 80;
    -fx-background-color: transparent;
    -fx-background-radius: 10;
    -fx-border-color: transparent;
    -fx-border-radius: 10;
    -fx-cursor: hand;
    -fx-alignment: center-left;
    -fx-wrap-text: true;
}

.category-tab:hover {
    -fx-background-color: rgba(91, 156, 245, 0.10);
    -fx-text-fill: -color-text;
}

.category-tab-active {
    -fx-background-color: rgba(91, 156, 245, 0.18);
    -fx-text-fill: -color-accent;
    -fx-border-color: transparent -color-accent transparent transparent;
    -fx-border-width: 0 3 0 0;
}

/* ── Prodotti (FlowPane) ─────────────────────────────────────────────────── */
.products-scroll {
    -fx-background: -color-bg;
    -fx-background-color: -color-bg;
}

.products-scroll>.viewport {
    -fx-background-color: -color-bg;
}

.products-pane {
    -fx-background-color: -color-bg;
    -fx-padding: 16;
}

/* ⚠️ CONFLITTO: ".prod-card" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


/* ── Card prodotto ───────────────────────────────────────────────────────── */
.prod-card {
    -fx-background-color: -color-surface;
    -fx-background-radius: 16;
    -fx-border-color: -color-border;
    -fx-border-radius: 16;
    -fx-border-width: 1;
    -fx-cursor: hand;
    -fx-min-height: 200;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.30), 6, 0, 0, 2);
}

/* ⚠️ CONFLITTO: ".prod-card:hover" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.prod-card:hover {
    -fx-border-color: -color-accent;
    -fx-background-color: -color-surface2;
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.22), 12, 0, 0, 3);
}

/* ⚠️ CONFLITTO: ".prod-name" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


.prod-name {
    -fx-font-size: 31px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
}

/* ⚠️ CONFLITTO: ".prod-price" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.prod-price {
    -fx-font-size: 30px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-accent;
}

/* ⚠️ CONFLITTO: ".prod-desc" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.prod-desc {
    -fx-font-size: 14px;
    -fx-text-fill: -color-muted;
}

/* RIMOSSO: .prod-allergen-chips  (duplicato esatto della riga 237) */

/* ⚠️ CONFLITTO: ".prod-allergen-chip" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.prod-allergen-chip {
    -fx-background-color: rgba(224, 160, 64, 0.15);
    -fx-background-radius: 6;
    -fx-border-color: rgba(224, 160, 64, 0.4);
    -fx-border-radius: 6;
    -fx-border-width: 1;
    -fx-text-fill: -color-orange;
    -fx-font-size: 12px;
    -fx-font-weight: bold;
    -fx-padding: 3 9;
}

/* ══════════════════════════════════════════════════════════════════
 *  ProductCard — stili aggiuntivi
 *  Incolla in dark.css e light.css dopo i blocchi .prod-* esistenti
 * ══════════════════════════════════════════════════════════════════ */

/* ── Card base ────────────────────────────────────────────────────── */
.prod-card {
    -fx-background-color: -color-surface;
    -fx-background-radius: 16;
    -fx-border-color: -color-border;
    -fx-border-radius: 16;
    -fx-border-width: 1;
    -fx-cursor: hand;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.22), 8, 0, 0, 3);
}

.prod-card:hover {
    -fx-border-color: -color-accent;
    -fx-background-color: -color-surface2;
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.28), 16, 0, 0, 4);
}

/* ── Overlay sfumato sull'immagine ───────────────────────────────── */
.prod-card-img-overlay {
    -fx-background-color: linear-gradient(to bottom,
            transparent 40%,
            rgba(0, 0, 0, 0.45) 100%);
}

/* ── Placeholder (niente immagine) ───────────────────────────────── */
.prod-card-placeholder {
    -fx-background-color: linear-gradient(to bottom right,
            rgba(91, 156, 245, 0.18),
            rgba(91, 156, 245, 0.06));
}

/* ⚠️ CONFLITTO: ".prod-card-placeholder-letter" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


.prod-card-placeholder-letter {
    -fx-font-size: 64px;
    -fx-font-weight: bold;
    -fx-text-fill: rgba(91, 156, 245, 0.45);
}

/* ── Separatore ──────────────────────────────────────────────────── */
.prod-card-divider {
    -fx-background-color: -color-border;
    -fx-pref-height: 1;
    -fx-max-height: 1;
}

/* ── Testi ───────────────────────────────────────────────────────── */
.prod-name {
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
    -fx-wrap-text: true;
}

.prod-price {
    -fx-font-size: 26px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-accent;
}

.prod-desc {
    -fx-font-size: 14px;
    -fx-text-fill: -color-muted;
    -fx-wrap-text: true;
}

/* ── Chips allergeni ─────────────────────────────────────────────── */
.prod-allergen-chips {
    -fx-background-color: transparent;
}

.prod-allergen-chip {
    -fx-background-color: rgba(224, 160, 64, 0.14);
    -fx-background-radius: 6;
    -fx-border-color: rgba(224, 160, 64, 0.45);
    -fx-border-radius: 6;
    -fx-border-width: 1;
    -fx-text-fill: -color-orange;
    -fx-font-size: 12px;
    -fx-font-weight: bold;
    -fx-padding: 3 9;
}


/* (incolla solo nel light.css — sovrascrive i valori sopra)

.prod-card-placeholder {
    -fx-background-color: linear-gradient(
        to bottom right,
        rgba(43,110,212,0.12),
        rgba(43,110,212,0.04)
    );
}

.prod-card-placeholder-letter {
    -fx-text-fill: rgba(43,110,212,0.40);
}
*/

/* ── Modal ───────────────────────────────────────────────────────────────── */
.modal-overlay {
    -fx-background-color: rgba(0, 0, 0, 0.75);
}

.modal-card {
    -fx-background-color: -color-surface;
    -fx-background-radius: 22;
    -fx-border-color: -color-border;
    -fx-border-radius: 22;
    -fx-border-width: 1;
    -fx-max-width: 860;
    -fx-min-width: 400;
    -fx-max-height: 920;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.65), 28, 0, 0, 10);
    /* overflow hidden: il bottone verde rimane dentro i bordi arrotondati */
}

/* Header colorato del modal */
.modal-header {
    -fx-background-color: linear-gradient(to bottom, #1a2545, #14182e);
    -fx-padding: 32 32 26 32;
    -fx-background-radius: 22 22 0 0;
    -fx-border-color: transparent transparent rgba(91, 156, 245, 0.25) transparent;
    -fx-border-width: 0 0 1 0;
}

.modal-title {
    -fx-font-size: 32px;
    -fx-font-weight: bold;
    -fx-text-fill: #ffffff;
    -fx-wrap-text: true;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 2, 0, 0, 1);
}

.modal-price {
    -fx-font-size: 42px;
    -fx-font-weight: bold;
    -fx-text-fill: #7dd4fc;
}

/* Body modal scrollabile */
.modal-body-scroll {
    -fx-background-color: transparent;
    -fx-border-color: transparent;
}

.modal-body-scroll>.viewport {
    -fx-background-color: transparent;
}

.modal-body {
    -fx-background-color: transparent;
    -fx-padding: 22 28 28 28;
}

.modal-desc {
    -fx-font-size: 17px;
    -fx-text-fill: -color-muted;
    -fx-line-spacing: 3;
}

.modal-section-label {
    -fx-font-size: 14px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-dim;
    -fx-padding: 0 0 4 0;
}

/* Chips allergeni nel modal — più grandi e visibili */
.allergen-chips-pane {
    -fx-background-color: transparent;
}

.allergen-chip {
    -fx-background-color: rgba(224, 160, 64, 0.18);
    -fx-background-radius: 22;
    -fx-border-color: -color-orange;
    -fx-border-radius: 22;
    -fx-border-width: 1.5;
    -fx-text-fill: -color-orange;
    -fx-font-size: 15px;
    -fx-font-weight: bold;
    -fx-padding: 8 18;
}

/* Chips ingredienti nel modal */
.ingredients-pane {
    -fx-background-color: transparent;
}

.ingredient-chip {
    -fx-background-color: -color-surface2;
    -fx-background-radius: 10;
    -fx-border-color: -color-border;
    -fx-border-radius: 10;
    -fx-border-width: 1;
    -fx-text-fill: -color-text;
    -fx-font-size: 15px;
    -fx-padding: 8 16;
}

/* ⚠️ CONFLITTO: ".modal-close" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


/* Pulsante chiudi modal */
.modal-close {
    -fx-min-width: 46px;
    -fx-min-height: 46px;
    -fx-max-width: 46px;
    -fx-max-height: 46px;
    -fx-font-size: 18px;
    -fx-font-weight: bold;
    -fx-background-radius: 50%;
    -fx-border-radius: 50%;
    -fx-background-color: rgba(255, 255, 255, 0.08);
    -fx-border-color: rgba(255, 255, 255, 0.20);
    -fx-text-fill: -color-text;
    -fx-cursor: hand;
    -fx-padding: 0;
}

/* RIMOSSO: .modal-close:pressed  (duplicato esatto della riga 921) */


/* ── Info / errore ───────────────────────────────────────────────────────── */
.info-label {
    -fx-font-size: 20px;
    -fx-text-fill: -color-muted;
    -fx-text-alignment: center;
    -fx-alignment: center;
    -fx-padding: 60 40;
    -fx-wrap-text: true;
}

/* ── Label base ──────────────────────────────────────────────────────────── */
.label {
    -fx-text-fill: -color-text;
}

/* ── Scroll bars ─────────────────────────────────────────────────────────── */
.scroll-bar {
    -fx-background-color: transparent;
    -fx-padding: 1;
}

.scroll-bar:vertical {
    -fx-pref-width: 6;
    -fx-min-width: 6;
    -fx-max-width: 6;
}

.scroll-bar:horizontal {
    -fx-pref-height: 6;
    -fx-min-height: 6;
    -fx-max-height: 6;
}

.scroll-bar .track {
    -fx-background-color: transparent;
}

.scroll-bar .thumb {
    -fx-background-color: rgba(150, 150, 200, 0.22);
    -fx-background-radius: 3;
}

.scroll-bar .thumb:pressed {
    -fx-background-color: rgba(150, 150, 200, 0.50);
}

.scroll-bar .increment-button,
.scroll-bar .decrement-button {
    -fx-background-color: transparent;
    -fx-padding: 0;
    -fx-pref-width: 0;
    -fx-pref-height: 0;
    -fx-min-width: 0;
    -fx-min-height: 0;
    -fx-max-width: 0;
    -fx-max-height: 0;
}

.scroll-bar .increment-arrow,
.scroll-bar .decrement-arrow {
    -fx-background-color: transparent;
    -fx-padding: 0;
    -fx-shape: "";
    -fx-min-width: 0;
    -fx-min-height: 0;
    -fx-max-width: 0;
    -fx-max-height: 0;
}

.scroll-pane {
    -fx-background-color: transparent;
    -fx-padding: 0;
}

.scroll-pane>.viewport {
    -fx-background-color: transparent;
}

.scroll-pane>.corner {
    -fx-background-color: transparent;
}

/* ── Button base ─────────────────────────────────────────────────────────── */
.button {
    -fx-background-color: -color-surface2;
    -fx-text-fill: -color-text;
    -fx-background-radius: 10;
    -fx-border-radius: 10;
    -fx-border-color: -color-border;
    -fx-border-width: 1;
    -fx-cursor: hand;
    -fx-padding: 10 20;
    -fx-font-size: 15px;
}

.button:pressed {
    -fx-background-color: -color-border;
    -fx-effect: none;
}

/* ══════════════════════════════════════════════════════════════════════
 *  NUOVE SCHERMATE — Welcome / Cart / Payment / Confirm
 * ══════════════════════════════════════════════════════════════════════ */

/* ── Radice schermate ────────────────────────────────────────────────── */
.screen-root {
    -fx-background-color: -color-bg;
}

.screen-header {
    -fx-background-color: #10101a;
    -fx-padding: 14 24;
    -fx-min-height: 72;
    -fx-border-color: transparent transparent -color-border transparent;
    -fx-border-width: 0 0 1 0;
}

.screen-title {
    -fx-font-size: 26px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
}

/* ⚠️ CONFLITTO: ".back-btn" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.back-btn {
    -fx-background-color: -color-surface2;
    -fx-text-fill: -color-text;
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-background-radius: 12;
    -fx-border-radius: 12;
    -fx-border-color: -color-border;
    -fx-min-width: 56;
    -fx-min-height: 56;
    -fx-cursor: hand;
}

/* RIMOSSO: .back-btn:pressed  (duplicato esatto della riga 939) */


/* ── CTA button (verde) ──────────────────────────────────────────────── */
.cta-btn {
    -fx-background-color: linear-gradient(to bottom, #3dbb6e, #2ea058);
    -fx-text-fill: white;
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-background-radius: 16;
    -fx-border-radius: 16;
    -fx-padding: 22 40;
    -fx-cursor: hand;
    -fx-effect: dropshadow(gaussian, rgba(46, 160, 88, 0.35), 10, 0, 0, 3);
}

.cta-btn:pressed {
    -fx-background-color: #267a44;
    -fx-effect: none;
}

.cta-btn:disabled {
    -fx-opacity: 0.4;
}

/* ── Pulsante aggiungi al carrello nel modal ─────────────────────────── */
.add-to-cart-btn {
    -fx-background-color: linear-gradient(to bottom, #3dbb6e, #2ea058);
    -fx-text-fill: white;
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-background-radius: 0 0 20 20;
    -fx-border-radius: 0 0 20 20;
    -fx-padding: 22 24;
    -fx-cursor: hand;
    -fx-min-height: 72;
}

.add-to-cart-btn:pressed {
    -fx-background-color: #1e7a3e;
    -fx-effect: none;
}

/* ⚠️ CONFLITTO: ".cart-btn" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


/* ── Pulsante carrello nell'header ───────────────────────────────────── */
.cart-btn {
    -fx-background-color: -color-surface2;
    -fx-border-color: -color-border;
    -fx-border-radius: 16;
    -fx-background-radius: 16;
    -fx-font-size: 28px;
    -fx-min-width: 64;
    -fx-min-height: 64;
    -fx-max-width: 64;
    -fx-max-height: 64;
    -fx-cursor: hand;
    -fx-padding: 0;
}

/* RIMOSSO: .cart-btn:pressed  (duplicato esatto della riga 860) */


.cart-badge {
    -fx-background-color: -color-red;
    -fx-background-radius: 14;
    -fx-text-fill: white;
    -fx-font-size: 14px;
    -fx-font-weight: bold;
    -fx-min-width: 28;
    -fx-min-height: 28;
    -fx-max-width: 28;
    -fx-max-height: 28;
    -fx-alignment: center;
    -fx-translate-x: 8;
    -fx-translate-y: -8;
}

/* ── Toast "Aggiunto!" ───────────────────────────────────────────────── */
.toast-label {
    -fx-background-color: rgba(46, 160, 88, 0.92);
    -fx-background-radius: 30;
    -fx-text-fill: white;
    -fx-font-size: 20px;
    -fx-font-weight: bold;
    -fx-padding: 16 36;
    -fx-translate-y: -40;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.35), 8, 0, 0, 3);
}

/* ══════════════════════════════════════════════════════════════════════
 *  WELCOME SCREEN
 * ══════════════════════════════════════════════════════════════════════ */
.welcome-root {
    -fx-background-color: linear-gradient(to bottom, #0d0d18, #16161e);
}

.welcome-container {
    -fx-padding: 60 40;
}

.welcome-logo {
    -fx-font-size: 90px;
}

.welcome-title {
    -fx-font-size: 56px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
    -fx-padding: 12 0 0 0;
}

.welcome-subtitle {
    -fx-font-size: 24px;
    -fx-text-fill: -color-muted;
    -fx-padding: 0 0 10 0;
}

.welcome-choose-lang {
    -fx-font-size: 20px;
    -fx-text-fill: -color-dim;
    -fx-font-weight: bold;
    -fx-padding: 0 0 8 0;
}

/* Pulsanti lingua */
/* ── Bottone lingua — base ────────────────────────────────────────── */
.lang-btn {
    -fx-background-color: -color-surface;
    -fx-background-radius: 24;
    -fx-border-color: -color-border;
    -fx-border-radius: 24;
    -fx-border-width: 2;
    -fx-cursor: hand;
    -fx-alignment: center;
    -fx-content-display: graphic-only;
    -fx-padding: 24;
    -fx-min-width: 220;
    -fx-min-height: 220;
    -fx-pref-width: 220;
    -fx-pref-height: 220;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.22), 8, 0, 0, 3);
}

.lang-btn:hover {
    -fx-border-color: -color-accent;
    -fx-background-color: -color-surface2;
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.28), 16, 0, 0, 4);
    -fx-scale-x: 1.04;
    -fx-scale-y: 1.04;
}

.lang-btn:pressed {
    -fx-scale-x: 0.96;
    -fx-scale-y: 0.96;
    -fx-effect: none;
}

/* Stato attivo (lingua selezionata) */
.lang-btn-active {
    -fx-border-color: -color-accent;
    -fx-border-width: 3.5;
    -fx-background-color: rgba(91, 156, 245, 0.12);
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.40), 18, 0, 0, 4);
}

/* Testo nome lingua sotto la bandiera */
.lang-btn-text {
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
    -fx-text-alignment: center;
    -fx-alignment: center;
}

/* Pulsante start */
.start-btn {
    -fx-background-color: linear-gradient(to bottom right, #4888e0, #3060c0);
    -fx-text-fill: white;
    -fx-font-size: 26px;
    -fx-font-weight: bold;
    -fx-background-radius: 20;
    -fx-border-radius: 20;
    -fx-padding: 24 60;
    -fx-cursor: hand;
    -fx-effect: dropshadow(gaussian, rgba(72, 136, 224, 0.45), 14, 0, 0, 4);
}

.start-btn:pressed {
    -fx-background-color: #2a50a0;
    -fx-effect: none;
}

/* ══════════════════════════════════════════════════════════════════════
 *  CART SCREEN
 * ══════════════════════════════════════════════════════════════════════ */
.cart-scroll {
    -fx-background: -color-bg;
    -fx-background-color: -color-bg;
}

.cart-scroll>.viewport {
    -fx-background-color: -color-bg;
}

.cart-list {
    -fx-background-color: -color-bg;
    -fx-padding: 20 24;
}

/* ⚠️ CONFLITTO: ".cart-row" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


.cart-row {
    -fx-background-color: -color-surface;
    -fx-background-radius: 16;
    -fx-border-color: -color-border;
    -fx-border-radius: 16;
    -fx-border-width: 1;
    -fx-padding: 20 22;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.20), 4, 0, 0, 1);
}

.cart-item-name {
    -fx-font-size: 20px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
}

.cart-item-price {
    -fx-font-size: 16px;
    -fx-text-fill: -color-muted;
}

.cart-item-total {
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-accent;
}

.cart-total-badge {
    -fx-background-color: -color-accent;
    -fx-text-fill: white;
    -fx-font-size: 18px;
    -fx-font-weight: bold;
    -fx-background-radius: 14;
    -fx-padding: 8 18;
}

.qty-btn {
    -fx-background-color: -color-surface2;
    -fx-text-fill: -color-text;
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-background-radius: 10;
    -fx-border-color: -color-border;
    -fx-border-radius: 10;
    -fx-min-width: 52;
    -fx-min-height: 52;
    -fx-cursor: hand;
}

.qty-btn:pressed {
    -fx-background-color: -color-border;
}

.qty-label {
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-min-width: 44;
    -fx-alignment: center;
}

.cart-footer {
    -fx-background-color: #10101a;
    -fx-border-color: -color-border transparent transparent transparent;
    -fx-border-width: 1 0 0 0;
    -fx-padding: 0;
}

.cart-total-row {
    -fx-padding: 20 28;
}

.cart-total-label {
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-muted;
}

.cart-total-amount {
    -fx-font-size: 34px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-accent;
}

.cart-proceed-hint {
    -fx-font-size: 14px;
    -fx-text-fill: -color-text;
    -fx-background-color: rgba(255, 255, 255, 0.08);
    -fx-background-radius: 14;
    -fx-padding: 10 18;
    -fx-alignment: center-left;
    -fx-max-width: 100%;
}

.cart-empty-label {
    -fx-font-size: 24px;
    -fx-text-fill: -color-dim;
    -fx-padding: 80 40;
    -fx-alignment: center;
    -fx-text-alignment: center;
}

/* ══════════════════════════════════════════════════════════════════════
 *  PAYMENT SCREEN
 * ══════════════════════════════════════════════════════════════════════ */
.payment-container {
    -fx-background-color: -color-bg;
    -fx-padding: 0 60 60 60;
}

.payment-topbar {
    -fx-padding: 20 0 0 0;
}

.payment-title {
    -fx-font-size: 38px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
    -fx-padding: 20 0 0 0;
    -fx-text-alignment: center;
    -fx-alignment: center;
}

.payment-total {
    -fx-font-size: 52px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-accent;
    -fx-text-alignment: center;
    -fx-alignment: center;
}

.payment-card {
    -fx-background-color: -color-surface;
    -fx-background-radius: 24;
    -fx-border-color: -color-border;
    -fx-border-radius: 24;
    -fx-border-width: 2;
    -fx-padding: 50 60;
    -fx-min-width: 300;
    -fx-min-height: 280;
    -fx-cursor: hand;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.25), 10, 0, 0, 3);
}

.payment-card:hover {
    -fx-border-color: -color-accent;
    -fx-background-color: -color-surface2;
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.30), 16, 0, 0, 4);
}

.payment-card-selected {
    -fx-border-color: -color-green;
    -fx-background-color: rgba(78, 201, 122, 0.12);
}

.payment-icon {
    -fx-font-size: 64px;
}

.payment-method-title {
    -fx-font-size: 26px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
}

.payment-method-sub {
    -fx-font-size: 18px;
    -fx-text-fill: -color-muted;
}

/* ⚠️ CONFLITTO: ".confirm-root" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


/* ══════════════════════════════════════════════════════════════════════
 *  CONFIRM SCREEN
 * ══════════════════════════════════════════════════════════════════════ */
.confirm-root {
    -fx-background-color: linear-gradient(to bottom, #0a1a0e, #12241a, #16161e);
}

/* ⚠️ CONFLITTO: ".confirm-container" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.confirm-container {
    -fx-padding: 60 40;
}

.check-circle {
    -fx-background-color: linear-gradient(to bottom right, #3dbb6e, #2ea058);
    -fx-background-radius: 50%;
    -fx-min-width: 160;
    -fx-min-height: 160;
    -fx-max-width: 160;
    -fx-max-height: 160;
    -fx-effect: dropshadow(gaussian, rgba(46, 160, 88, 0.55), 24, 0, 0, 6);
}

/* ⚠️ CONFLITTO: ".check-icon" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.check-icon {
    -fx-font-size: 80px;
    -fx-font-weight: bold;
    -fx-text-fill: white;
}

/* ⚠️ CONFLITTO: ".confirm-title" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


.confirm-title {
    -fx-font-size: 48px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
    -fx-text-alignment: center;
}

.confirm-number-sub {
    -fx-font-size: 22px;
    -fx-text-fill: -color-muted;
}

.confirm-number {
    -fx-font-size: 120px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-accent;
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.4), 16, 0, 0, 0);
}

/* ⚠️ CONFLITTO: ".confirm-msg" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.confirm-msg {
    -fx-font-size: 24px;
    -fx-text-fill: -color-muted;
    -fx-text-alignment: center;
    -fx-alignment: center;
    -fx-line-spacing: 6;
}

.confirm-countdown {
    -fx-font-size: 18px;
    -fx-text-fill: -color-dim;
}

/* ⚠️ CONFLITTO: ".cart-allergen-warning" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


/* ── Cart allergen warning ─────────────────────────────────────────── */
.cart-allergen-warning {
    -fx-background-color: rgba(224, 160, 64, 0.12);
    -fx-border-color: rgba(224, 160, 64, 0.35);
    -fx-border-width: 1 0 0 0;
    -fx-padding: 16 24;
}

/* ⚠️ CONFLITTO: ".cart-allergen-icon" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.cart-allergen-icon {
    -fx-font-size: 28px;
}

/* ⚠️ CONFLITTO: ".cart-allergen-title" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.cart-allergen-title {
    -fx-font-size: 16px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-orange;
}

.cart-item-allergen-chip {
    -fx-background-color: rgba(224, 160, 64, 0.12);
    -fx-background-radius: 5;
    -fx-border-color: rgba(224, 160, 64, 0.30);
    -fx-border-radius: 5;
    -fx-border-width: 1;
    -fx-text-fill: -color-orange;
    -fx-font-size: 11px;
    -fx-padding: 2 7;
}

/* ══════════════════════════════════════════════════════════════════════
 *  SPLASH SCREEN
 * ══════════════════════════════════════════════════════════════════════ */
.splash-root {
    -fx-background-color: linear-gradient(to bottom right, #0d0d1a, #111128, #0a0a16);
}

/* Cerchi decorativi animati */
.splash-circle-1 {
    -fx-background-color: rgba(91, 156, 245, 0.06);
    -fx-background-radius: 50%;
    -fx-border-color: rgba(91, 156, 245, 0.12);
    -fx-border-radius: 50%;
    -fx-border-width: 1;
    -fx-min-width: 600;
    -fx-min-height: 600;
    -fx-max-width: 600;
    -fx-max-height: 600;
}

.splash-circle-2 {
    -fx-background-color: rgba(91, 156, 245, 0.04);
    -fx-background-radius: 50%;
    -fx-border-color: rgba(91, 156, 245, 0.08);
    -fx-border-radius: 50%;
    -fx-border-width: 1;
    -fx-min-width: 380;
    -fx-min-height: 380;
    -fx-max-width: 380;
    -fx-max-height: 380;
}

.splash-container {
    -fx-padding: 80 60;
}

.splash-logo {
    -fx-font-size: 100px;
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.4), 20, 0, 0, 0);
}

.splash-app-name {
    -fx-font-size: 38px;
    -fx-font-weight: bold;
    -fx-text-fill: white;
    -fx-padding: 16 0 6 0;
}

.splash-app-sub {
    -fx-font-size: 18px;
    -fx-text-fill: rgba(255, 255, 255, 0.45);
}

.splash-step-icon {
    -fx-font-size: 36px;
    -fx-padding: 0 0 10 0;
}

.splash-step-label {
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-text-fill: rgba(255, 255, 255, 0.90);
    -fx-padding: 0 0 6 0;
}

.splash-detail {
    -fx-font-size: 15px;
    -fx-text-fill: rgba(255, 255, 255, 0.40);
}

/* Barra progresso custom */
.splash-progress {
    -fx-accent: -color-accent;
    -fx-background-color: rgba(255, 255, 255, 0.08);
    -fx-background-radius: 5;
    -fx-pref-height: 8;
}

.splash-progress>.track {
    -fx-background-color: rgba(255, 255, 255, 0.08);
    -fx-background-radius: 5;
}

.splash-progress>.bar {
    -fx-background-color: linear-gradient(to right, #3a78e0, -color-accent);
    -fx-background-radius: 5;
    -fx-background-insets: 0;
}

.splash-version {
    -fx-font-size: 13px;
    -fx-text-fill: rgba(255, 255, 255, 0.20);
    -fx-padding: 0 0 20 0;
}

/* ══════════════════════════════════════════════════════════════════════
 *  IKONLI — Stili icone MDI2
 * ══════════════════════════════════════════════════════════════════════ */

/* Icone status bar */
.status-icon {
    -fx-icon-color: -color-muted;
}

.status-icon-online {
    -fx-icon-color: -color-green;
}

.status-icon-offline {
    -fx-icon-color: -color-red;
}

/* Icone tema */
.theme-icon {
    -fx-icon-color: -color-muted;
}

.theme-btn {
    -fx-background-color: -color-surface2;
    -fx-border-color: -color-border;
    -fx-border-radius: 50%;
    -fx-background-radius: 50%;
    -fx-min-width: 44;
    -fx-min-height: 44;
    -fx-max-width: 44;
    -fx-max-height: 44;
    -fx-cursor: hand;
    -fx-padding: 0;
}

.theme-btn:pressed {
    -fx-background-color: -color-border;
}

/* Icona header menu */
.shop-header-icon {
    -fx-icon-color: -color-accent;
}

.screen-header-icon {
    -fx-icon-color: -color-accent;
}

/* Icone carrello */
.cart-btn-icon {
    -fx-icon-color: -color-text;
}

.cart-btn {
    -fx-background-color: -color-surface2;
    -fx-border-color: -color-border;
    -fx-border-radius: 16;
    -fx-background-radius: 16;
    -fx-min-width: 64;
    -fx-min-height: 64;
    -fx-max-width: 64;
    -fx-max-height: 64;
    -fx-cursor: hand;
    -fx-padding: 0;
}

.cart-btn:pressed {
    -fx-background-color: -color-border;
}

/* Quick cart shortcut */
.quick-cart-btn {
    -fx-background-color: -color-accent;
    -fx-text-fill: white;
    -fx-border-radius: 14;
    /* pill/rounded rectangle */
    -fx-background-radius: 14;
    -fx-background-insets: 0;
    -fx-border-insets: 0;
    -fx-padding: 0 18;
    -fx-min-width: 160;
    -fx-min-height: 54;
    -fx-max-width: 240;
    -fx-max-height: 54;
    -fx-cursor: hand;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.35), 14, 0, 0, 0);
}

.quick-cart-btn:hover {
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.45), 18, 0, 0, 0);
}

.quick-cart-btn:pressed {
    -fx-background-color: rgba(91, 156, 245, 0.85);
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.28), 12, 0, 0, 0);
}

.quick-cart-icon {
    -fx-icon-color: white;
}

/* ⚠️ CONFLITTO: ".compose-kumpir-btn" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */


.compose-kumpir-btn {
    -fx-background-color: linear-gradient(to bottom right, #2ea632, #1f8c2f);
    -fx-text-fill: white;
    -fx-font-size: 14px;
    -fx-font-weight: bold;
    -fx-border-color: #37b13c;
    -fx-border-width: 2;
    -fx-border-radius: 16;
    -fx-background-radius: 16;
    -fx-min-width: 180;
    -fx-min-height: 52;
    -fx-cursor: hand;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.35), 14, 0, 0, 0);
}

/* ⚠️ CONFLITTO: ".compose-kumpir-btn:hover" è definito più volte con contenuto diverso.
   Verifica quale versione usare e rimuovi le altre. */

.compose-kumpir-btn:hover {
    -fx-background-color: linear-gradient(to bottom right, #35c23f, #23922e);
}

.ingredient-checkbox {
    -fx-font-size: 16px;
    -fx-padding: 8 12;
    -fx-border-radius: 8;
    -fx-background-radius: 8;
    -fx-border-color: -color-border;
    -fx-background-color: -color-surface2;
    -fx-text-fill: -color-text;
}

/* Icona aggiungi al carrello */
.add-to-cart-icon {
    -fx-icon-color: white;
}

/* Icona modal chiudi */
.modal-close {
    -fx-background-color: rgba(255, 255, 255, 0.08);
    -fx-border-color: rgba(255, 255, 255, 0.20);
    -fx-border-radius: 50%;
    -fx-background-radius: 50%;
    -fx-min-width: 46;
    -fx-min-height: 46;
    -fx-max-width: 46;
    -fx-max-height: 46;
    -fx-cursor: hand;
    -fx-padding: 0;
}

.modal-close:pressed {
    -fx-background-color: rgba(224, 85, 85, 0.30);
    -fx-border-color: -color-red;
}

.modal-close-icon {
    -fx-icon-color: -color-text;
}

/* Icone sezioni modal */
.allergen-icon {
    -fx-icon-color: -color-orange;
}

.ingredient-icon {
    -fx-icon-color: -color-muted;
}

/* Icone pagamento */
.payment-header-icon {
    -fx-icon-color: -color-accent;
}

.payment-cash-icon {
    -fx-icon-color: -color-green;
}

.payment-card-icon-style {
    -fx-icon-color: -color-accent;
}

/* Icona back */
.back-icon {
    -fx-icon-color: -color-text;
}

.back-btn {
    -fx-background-color: -color-surface2;
    -fx-text-fill: -color-text;
    -fx-background-radius: 12;
    -fx-border-radius: 12;
    -fx-border-color: -color-border;
    -fx-min-width: 56;
    -fx-min-height: 56;
    -fx-cursor: hand;
}

.back-btn:pressed {
    -fx-background-color: -color-border;
}

/* CTA icon */
.cta-icon {
    -fx-icon-color: white;
}

/* Toast */
.toast-icon {
    -fx-icon-color: white;
}

.toast-text {
    -fx-text-fill: white;
    -fx-font-size: 20px;
    -fx-font-weight: bold;
}

/* Welcome logo */
.welcome-logo-icon {
    -fx-icon-color: -color-accent;
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.4), 20, 0, 0, 0);
}

/* Start btn icon */
.start-btn-icon {
    -fx-icon-color: white;
}

/* Splash */
.splash-logo-icon {
    -fx-icon-color: -color-accent;
    -fx-effect: dropshadow(gaussian, rgba(91, 156, 245, 0.4), 20, 0, 0, 0);
}

.splash-step-icon-node {
    -fx-icon-color: -color-accent;
}

/* Confirm check */
.check-icon {
    -fx-icon-color: white;
}

/* Cart allergen icon */
.cart-allergen-icon {
    -fx-icon-color: -color-orange;
}

/* Confirm modal */
.confirm-root {
    -fx-background-color: rgba(0, 0, 0, 0.55);
}

.confirm-container {
    -fx-background-color: -color-surface;
    -fx-background-radius: 24;
    -fx-padding: 28;
    -fx-alignment: center;
    -fx-min-width: 340;
}

.confirm-title {
    -fx-font-size: 24px;
    -fx-font-weight: bold;
    -fx-text-fill: -color-text;
}

.confirm-msg {
    -fx-font-size: 16px;
    -fx-text-fill: -color-muted;
}

.confirm-btn-primary {
    -fx-background-color: -color-accent;
    -fx-text-fill: white;
}

.confirm-btn-secondary {
    -fx-background-color: rgba(255, 255, 255, 0.15);
    -fx-text-fill: -color-text;
}

.confirm-btn-primary:hover {
    -fx-background-color: rgba(91, 156, 245, 0.9);
}

.confirm-btn-secondary:hover {
    -fx-background-color: rgba(255, 255, 255, 0.25);
}


/* ═══════════════════════════════════════════════════════════════════
   KUMPIR MODAL & COMPOSE BUTTON — CSS da aggiungere al tuo stylesheet
   ═══════════════════════════════════════════════════════════════════ */

/* ── Sidebar sinistra ─────────────────────────────────────────────── */

.sidebar-pane {
    -fx-background-color: #1a1a2e;
    -fx-border-color: transparent #2a2a4a transparent transparent;
    -fx-border-width: 0 1 0 0;
}

/* Contenitore del bottone kumpir (padding + sfondo degradato) */
.compose-kumpir-container {
    -fx-background-color: linear-gradient(to top, #0f0f1a, #1a1a2e);
    -fx-padding: 14 12 16 12;
    -fx-border-color: #2a2a4a transparent transparent transparent;
    -fx-border-width: 1 0 0 0;
}

/* ── Bottone "Componi il tuo Kumpir" ──────────────────────────────── */

.compose-kumpir-btn {
    -fx-background-color: linear-gradient(to bottom right, #f7971e, #ffd200);
    -fx-text-fill: #1a1000;
    -fx-font-size: 15px;
    -fx-font-weight: bold;
    -fx-padding: 18 14;
    -fx-background-radius: 14;
    -fx-cursor: hand;
    -fx-effect: dropshadow(gaussian, rgba(255, 200, 0, 0.45), 14, 0.3, 0, 4);
    -fx-wrap-text: true;
    -fx-text-alignment: center;
    -fx-border-radius: 14;
    -fx-min-height: 72px;
}

.compose-kumpir-btn:hover {
    -fx-background-color: linear-gradient(to bottom right, #ffa533, #ffe033);
    -fx-effect: dropshadow(gaussian, rgba(255, 210, 0, 0.65), 20, 0.4, 0, 6);
}

.compose-kumpir-btn:pressed {
    -fx-background-color: linear-gradient(to bottom right, #e68a00, #ecc200);
    -fx-effect: dropshadow(gaussian, rgba(255, 180, 0, 0.3), 8, 0.2, 0, 2);
    -fx-translate-y: 1;
}

/* ── Kumpir Modal Card ────────────────────────────────────────────── */

.kumpir-modal-card {
    -fx-background-color: #16162a;
    -fx-background-radius: 20;
    -fx-border-color: rgba(247, 151, 30, 0.25);
    -fx-border-width: 1.5;
    -fx-border-radius: 20;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.75), 40, 0.5, 0, 10);
}

/* ── Header del modal kumpir ─────────────────────────────────────── */

.kumpir-modal-header {
    -fx-background-color: linear-gradient(to right, #1e1e38, #252540);
    -fx-background-radius: 20 20 0 0;
    -fx-padding: 20 24 20 24;
    -fx-border-color: transparent transparent rgba(247, 151, 30, 0.18) transparent;
    -fx-border-width: 0 0 1 0;
}

.kumpir-modal-title {
    -fx-font-size: 22px;
    -fx-font-weight: bold;
    -fx-text-fill: #ffd200;
}

.kumpir-modal-subtitle {
    -fx-font-size: 13px;
    -fx-text-fill: #8888aa;
}

/* ── Barra filtri ───────────────────────────────────────────────── */

.kumpir-filter-bar {
    -fx-background-color: #1e1e38;
    -fx-border-color: transparent transparent rgba(255, 255, 255, 0.07) transparent;
    -fx-border-width: 0 0 1 0;
}

.kumpir-search-field {
    -fx-background-color: #252545;
    -fx-background-radius: 10;
    -fx-border-color: rgba(255, 255, 255, 0.1);
    -fx-border-radius: 10;
    -fx-border-width: 1;
    -fx-text-fill: #e0e0f0;
    -fx-prompt-text-fill: #6666aa;
    -fx-font-size: 15px;
    -fx-padding: 10 14;
}

.kumpir-search-field:focused {
    -fx-border-color: rgba(247, 151, 30, 0.55);
    -fx-effect: dropshadow(gaussian, rgba(247, 151, 30, 0.2), 8, 0.2, 0, 0);
}

/* ── Filter chips ────────────────────────────────────────────────── */

.kumpir-filter-chip {
    -fx-background-color: #2a2a50;
    -fx-text-fill: #9999cc;
    -fx-font-size: 13px;
    -fx-padding: 8 14;
    -fx-background-radius: 20;
    -fx-border-color: rgba(255, 255, 255, 0.1);
    -fx-border-radius: 20;
    -fx-border-width: 1;
    -fx-cursor: hand;
}

.kumpir-filter-chip:selected {
    -fx-background-color: linear-gradient(to right, #f7971e, #ffd200);
    -fx-text-fill: #1a1000;
    -fx-font-weight: bold;
    -fx-border-color: transparent;
    -fx-effect: dropshadow(gaussian, rgba(255, 200, 0, 0.3), 8, 0.2, 0, 0);
}


/* ── Griglia ingredienti ─────────────────────────────────────────── */

.kumpir-grid-scroll {
    -fx-background-color: transparent;
    -fx-background: transparent;
}

.kumpir-grid-scroll>.viewport {
    -fx-background-color: transparent;
}

.kumpir-ingredient-grid {
    -fx-background-color: transparent;
}

/* Card-toggle per ogni ingrediente */
.kumpir-ingredient-card {
    -fx-background-color: #252545;
    -fx-text-fill: #ccccee;
    -fx-background-radius: 14;
    -fx-border-color: rgba(255, 255, 255, 0.08);
    -fx-border-radius: 14;
    -fx-border-width: 1.5;
    -fx-cursor: hand;
    -fx-alignment: center;
    -fx-padding: 0;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.3), 6, 0.1, 0, 2);
}

.kumpir-ingredient-card:hover {
    -fx-background-color: #2e2e58;
    -fx-border-color: rgba(247, 151, 30, 0.4);
    -fx-effect: dropshadow(gaussian, rgba(247, 151, 30, 0.2), 10, 0.2, 0, 0);
}

.kumpir-ingredient-card:selected {
    -fx-background-color: linear-gradient(to bottom right, #2a1f00, #3d2e00);
    -fx-border-color: #ffd200;
    -fx-border-width: 2;
    -fx-effect: dropshadow(gaussian, rgba(255, 210, 0, 0.4), 12, 0.3, 0, 0);
}

.kumpir-ingredient-card:pressed {
    -fx-translate-y: 1;
    -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.2), 4, 0.1, 0, 1);
}

/* Testi dentro la card ingrediente */
.kumpir-ingredient-name {
    -fx-font-size: 14px;
    -fx-font-weight: bold;
    -fx-text-fill: #e0e0f8;
}

.kumpir-ingredient-card:selected .kumpir-ingredient-name {
    -fx-text-fill: #ffd200;
}

.kumpir-ingredient-price {
    -fx-font-size: 13px;
    -fx-text-fill: #7cba5a;
    -fx-font-weight: bold;
}

.kumpir-ingredient-card:selected .kumpir-ingredient-price {
    -fx-text-fill: #aadd77;
}

.kumpir-allergen-badge {
    -fx-font-size: 10px;
    -fx-text-fill: #e8a040;
    -fx-padding: 2 6 2 6;
    -fx-background-color: rgba(232, 160, 64, 0.12);
    -fx-background-radius: 6;
}

/* ── Barra totale ────────────────────────────────────────────────── */

.kumpir-total-bar {
    -fx-background-color: linear-gradient(to right, #1e1e38, #252540);
    -fx-background-radius: 0 0 20 20;
    -fx-border-color: rgba(247, 151, 30, 0.18) transparent transparent transparent;
    -fx-border-width: 1 0 0 0;
}

.kumpir-count-label {
    -fx-font-size: 13px;
    -fx-text-fill: #7777aa;
}

.kumpir-total-label {
    -fx-font-size: 26px;
    -fx-font-weight: bold;
    -fx-text-fill: #ffd200;
    -fx-effect: dropshadow(gaussian, rgba(255, 210, 0, 0.3), 8, 0.2, 0, 0);
}

/* Bottone aggiungi al carrello kumpir */
.kumpir-add-btn {
    -fx-background-color: linear-gradient(to bottom right, #28a745, #1e7e34);
    -fx-text-fill: white;
    -fx-font-size: 16px;
    -fx-font-weight: bold;
    -fx-padding: 16 28;
    -fx-background-radius: 12;
    -fx-border-radius: 12;
    -fx-cursor: hand;
    -fx-effect: dropshadow(gaussian, rgba(40, 167, 69, 0.4), 12, 0.3, 0, 4);
    -fx-min-height: 56px;
}

.kumpir-add-btn:hover {
    -fx-background-color: linear-gradient(to bottom right, #34c45a, #28a745);
    -fx-effect: dropshadow(gaussian, rgba(40, 200, 80, 0.5), 16, 0.4, 0, 6);
}

.kumpir-add-btn:pressed {
    -fx-background-color: linear-gradient(to bottom right, #1e7e34, #155724);
    -fx-effect: dropshadow(gaussian, rgba(40, 120, 69, 0.3), 6, 0.2, 0, 2);
    -fx-translate-y: 1;
}

/* ═══════════════════════════════════════════════════════
   CART — stili aggiuntivi (da aggiungere al CSS esistente)
   ═══════════════════════════════════════════════════════ */

/* ── Banner allergeni in fondo ─────────────────────────── */

.cart-allergen-warning {
    -fx-background-color: linear-gradient(to right, #2a1500, #3d2200);
    -fx-border-color: rgba(255, 160, 30, 0.35) transparent transparent transparent;
    -fx-border-width: 1.5 0 0 0;
    -fx-padding: 14 20 14 20;
}

.cart-allergen-icon {
    -fx-icon-color: #f7971e;
    -fx-fill: #f7971e;
}

.cart-allergen-title {
    -fx-font-size: 14px;
    -fx-font-weight: bold;
    -fx-text-fill: #ffb347;
}

/* ── Ingredienti nella riga carrello ───────────────────── */

.cart-item-ingredients {
    -fx-font-size: 12px;
    -fx-text-fill: #7a9e7a;
    /* verde muted — neutro, non invasivo */
    -fx-wrap-text: true;
    -fx-padding: 0 0 2 0;
}

/* ── Riga carrello (aggiustamento dopo aggiunta ingredienti) ── */

.cart-row {
    -fx-background-color: #1e1e38;
    -fx-background-radius: 14;
    -fx-border-color: rgba(255, 255, 255, 0.06);
    -fx-border-radius: 14;
    -fx-border-width: 1;
    -fx-padding: 14 16;
}


/* ── Ingrediente non disponibile ────────────────────────── */

/* Card disabilitata: opacità ridotta + cursore not-allowed */
.kumpir-ingredient-card.ingredient-unavailable {
    -fx-opacity: 0.38;
    -fx-cursor: default;
}

/* Etichetta "Non disponibile" al posto del prezzo */
.kumpir-ingredient-unavailable-label {
    -fx-font-size: 11px;
    -fx-text-fill: #cc6666;
    -fx-font-style: italic;
}