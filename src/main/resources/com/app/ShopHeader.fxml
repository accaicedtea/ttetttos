<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.app.controllers.ShopHeaderController"
    styleClass="top-container">

    <!-- Status bar -->
    <HBox alignment="CENTER_LEFT" spacing="18" styleClass="status-bar">
        <FontIcon fx:id="calendarIcon" iconLiteral="mdi2c-calendar" iconSize="16"
            styleClass="status-icon" />
        <Label fx:id="dateLabel" styleClass="status-date" />
        <FontIcon iconLiteral="mdi2c-clock-outline" iconSize="16" styleClass="status-icon" />
        <Label fx:id="clockLabel" styleClass="status-clock" />
        <Region HBox.hgrow="ALWAYS" />

        <!-- Stato rete con icona -->
        <HBox alignment="CENTER" spacing="8">
            <FontIcon fx:id="internetIcon" iconLiteral="mdi2w-wifi-off" iconSize="18"
                styleClass="status-icon-offline" />
            <Label fx:id="internetLabel" styleClass="status-text" text="Offline" />
        </HBox>

        <!-- Toggle tema -->
        <Button fx:id="themeBtn" onAction="#toggleTheme" styleClass="theme-btn"
            focusTraversable="false">
            <graphic>
                <FontIcon fx:id="themeIcon" iconLiteral="mdi2w-weather-night" iconSize="22"
                    styleClass="theme-icon" />
            </graphic>
        </Button>
    </HBox>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="shop-header">
        <FontIcon iconLiteral="mdi2f-food-fork-drink" iconSize="36" styleClass="shop-header-icon" />
        <VBox spacing="2">
            <Label fx:id="menuTitleLabel" text="Il Nostro Menu" styleClass="shop-header-title" />
            <Label fx:id="categoryTitleLabel" styleClass="shop-header-hint" text="Caricamento..." />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />

        <!-- Pulsante carrello con badge -->
        <StackPane>
            <Button fx:id="cartBtn" onAction="#onCartClick" styleClass="cart-btn"
                focusTraversable="false">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-cart" iconSize="30" styleClass="cart-btn-icon" />
                </graphic>
            </Button>
            <Label fx:id="cartBadge" text="0" styleClass="cart-badge" visible="false"
                managed="false" StackPane.alignment="TOP_RIGHT" />
        </StackPane>
    </HBox>
</VBox>