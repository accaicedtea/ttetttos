<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.app.controllers.WelcomeController"
  styleClass="welcome-root">

  <VBox spacing="0">
      
      <VBox fx:id="welcomeContainer" alignment="CENTER" spacing="0"
        styleClass="welcome-container" VBox.vgrow="ALWAYS">

        <!-- Logo -->
        <FontIcon iconLiteral="mdi2f-food-fork-drink" iconSize="100"
          styleClass="welcome-logo-icon" />

        <Label fx:id="titleLabel" text="BENVENUTO" styleClass="welcome-title" />
        <Label fx:id="subtitleLabel" text="TOCCA PER INIZIARE" styleClass="welcome-subtitle" />

        <Region prefHeight="20" />

        <Label fx:id="chooseLangLabel" text="SCEGLI LA TUA LINGUA"
          styleClass="welcome-choose-lang" />

        <Region prefHeight="24" />

        <!-- Riga 1+2: pulsanti lingua generati dinamicamente da WelcomeController -->
        <FlowPane fx:id="languagePane" hgap="24" vgap="24" alignment="CENTER" prefWrapLength="600" />

        <Region prefHeight="20" />

        <Region prefHeight="88" />

        <!-- Pulsante start -->
        <Button fx:id="startBtn" onAction="#onStart"
          styleClass="start-btn"
          text="INIZIA L'ORDINE  →"
          minWidth="400" minHeight="80"
          visible="false" managed="false">
          <graphic>
            <FontIcon iconLiteral="mdi2a-arrow-right-circle" iconSize="32"
              styleClass="start-btn-icon" />
          </graphic>
        </Button>

      </VBox>

      <!-- Global Footer -->
      <HBox alignment="CENTER" styleClass="global-footer" style="-fx-padding: 10;" VBox.vgrow="NEVER">
          <Label text="Totem Kiosk v1.0 | © 2026 TOTTEM" style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
      </HBox>

  </VBox>

</StackPane>
