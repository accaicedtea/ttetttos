<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
╔════════════════════════════════════════════════════════════════════╗
║                    ALLERGEN BANNER COMPONENT                       ║
╠════════════════════════════════════════════════════════════════════╣
║ Banner avviso allergie con:                                        ║
║ • Icona alert                                                      ║
║ • Titolo avviso                                                    ║
║ • Chip allergeni                                                   ║
╚════════════════════════════════════════════════════════════════════╝
-->

<HBox xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.app.components.AllergenBannerController"
    spacing="12" alignment="CENTER_LEFT"
    styleClass="allergen-warning"
    visible="false" managed="false">

    <!-- Icona alert -->
    <FontIcon iconLiteral="mdi2a-alert-rhombus" iconSize="28"
        styleClass="allergen-icon" />

    <!-- Testo e chip -->
    <VBox spacing="6" HBox.hgrow="ALWAYS">
        <Label fx:id="titleLabel"
            text="ATTENZIONE: ALLERGENI NEL TUO ORDINE"
            styleClass="allergen-title" />
        <FlowPane fx:id="allergenChips" hgap="8" vgap="6"
            styleClass="allergen-chips-pane" />
    </VBox>

</HBox>
